generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id      Int      @id @default(autoincrement())
  name    String
  contact String   @unique
  time    DateTime @default(now())
}

model Order {
  id        Int        @id @default(autoincrement())
  number    String
  locations Location[]
}

model Location {
  id      Int      @id @default(autoincrement())
  address String
  time    DateTime @default(now())
  Order   Order?   @relation(fields: [orderId], references: [id])
  orderId Int?
}
