generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id      Int      @id @default(autoincrement())
  name    String
  contact String   @unique
  time    DateTime @default(now())
}

model Order {
  id        Int      @id @default(autoincrement())
  number    String   @unique
  locations String
  time      DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}
